PORT=5000
NODE_ENV=development

# Database (Default Postgres credentials, update if necessary)
PGUSER=postgres
PGPASSWORD=your_postgres_password_here
PGHOST=localhost
PGPORT=5432
PGDATABASE=habitforge

# Authentication
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=30d

# AI Integration
GEMINI_API_KEY=your_gemini_api_key_here

# Client
FRONTEND_URL=http://localhost:5173
